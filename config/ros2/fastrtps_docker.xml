<?xml version="1.0" encoding="UTF-8" ?>
<!--
  FastRTPS UDP-only transport profile — Docker compatibility
  Issue: FastRTPS shared memory transport fails when ROS2 nodes are
  launched from separate `docker exec` sessions within the same container.
  Nodes discover each other (UDP multicast works), but data messages
  never arrive (SHM segments are isolated per session).
  Fix: Disable shared memory, force UDPv4 only.
  Usage: export FASTRTPS_DEFAULT_PROFILES_FILE=file:///tmp/fastrtps_docker.xml
-->
<profiles>
  <participant profile_name="default" is_default_profile="true">
    <rtps>
      <userTransports>
        <transport_id>udp_only</transport_id>
      </userTransports>
      <useBuiltinTransports>false</useBuiltinTransports>
    </rtps>
  </participant>
  <transport_descriptors>
    <transport_descriptor>
      <transport_id>udp_only</transport_id>
      <type>UDPv4</type>
    </transport_descriptor>
  </transport_descriptors>
</profiles>
